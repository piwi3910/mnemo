# Un-ignore the notes/ source directory (root .gitignore has a blanket `notes/` pattern
# that would otherwise swallow packages/ui/src/notes/).
!src/notes/
!src/notes/**

# Un-ignore search/ and tags/ in case root patterns cover them.
!src/search/
!src/search/**
!src/tags/
!src/tags/**

# Un-ignore new module directories.
!src/sharing/
!src/sharing/**
!src/trash/
!src/trash/**
!src/daily/
!src/daily/**
!src/templates/
!src/templates/**
