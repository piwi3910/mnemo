{
  "name": "@azrtydxb/core",
  "version": "4.4.0-pre.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run generate && tsc -b",
    "clean": "rm -rf dist",
    "generate": "tsx scripts/generate-schema.ts",
    "verify-generated": "tsx scripts/verify-generated.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/azrtydxb/kryton.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "dependencies": {
    "yjs": "^13.6.0",
    "y-protocols": "^1.0.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6",
    "@types/node": "^22",
    "better-sqlite3": "^11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "license": "see LICENSE"
}
